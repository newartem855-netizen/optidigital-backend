# ─── Required ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Project (must match a file in src/config/prompts/) ─
PROJECT_ID=optidigital

# ─── OpenAI settings ────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# ─── Memory ─────────────────────────────────────────────
MAX_HISTORY=20

# ─── Rate limiting ───────────────────────────────────────
RATE_WINDOW_MS=60000
RATE_MAX_REQUESTS=20

# ─── Server ──────────────────────────────────────────────
PORT=3000
